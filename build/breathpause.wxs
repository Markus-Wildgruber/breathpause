<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v5 source for the breathpause Windows installer (winget needs an installer artifact,
  not a bare .ps1). The MSI drops the single-file bundle into Program Files and adds a Start
  Menu shortcut that launches it via powershell.exe. The bundle self-relaunches under STA and
  hides its console, so the shortcut just needs -ExecutionPolicy Bypass.

  Build (see build/build-msi.ps1):
    wix build build/breathpause.wxs -d Version=0.1.0 -d ScriptPath=dist/breathpause.ps1 -o dist/breathpause.msi

  NOTE: unsigned. Windows shows an "unknown publisher" UAC prompt on this per-machine install.
  Removing that prompt requires an Authenticode/EV certificate (paid) — see RELEASING.md.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="breathpause"
           Manufacturer="Markus Wildgruber"
           Version="$(var.Version)"
           UpgradeCode="f9c29492-b3e3-4de4-bf07-ad0a9dd9f5b1"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of breathpause is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="breathpause">
        <Component Id="MainScript" Guid="*">
          <File Id="breathpauseScript" Name="breathpause.ps1" Source="$(var.ScriptPath)" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="breathpause">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="AppShortcut"
                    Name="breathpause"
                    Description="An always-on-top breathing bubble that paces your focus sessions."
                    Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
                    Arguments="-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLFOLDER]breathpause.ps1&quot;"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
          <!-- Per-WiX convention, a non-advertised shortcut component needs a keypath; an
               HKCU registry value is the standard choice. -->
          <RegistryValue Root="HKCU" Key="Software\breathpause" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="breathpause">
      <ComponentRef Id="MainScript" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Package>
</Wix>
