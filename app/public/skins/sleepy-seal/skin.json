{
  "name": "Sleepy Seal",
  "author": "breathpause (art: openclipart.org, public domain)",
  "svg": "skin.svg",
  "bindings": [
    { "target": "seal",      "property": "scale", "source": "breath", "from": 1.0,  "to": 1.05, "origin": [500, 740] },
    { "target": "bubble",    "property": "r",     "source": "breath", "from": 52,   "to": 12 },
    { "target": "bubble",    "property": "opacity", "source": "breath", "from": 0.92, "to": 0.65 },
    { "target": "bubble-hi", "property": "r",     "source": "breath", "from": 12,   "to": 3 }
  ],
  "text": { "anchor": "below", "color": "#cfe3f5" }
}
